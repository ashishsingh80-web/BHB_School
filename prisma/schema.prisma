// BHB International School ERP — synced toward the Ultimate Master Blueprint

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  MANAGEMENT
  PRINCIPAL
  OFFICE_ADMIN
  ADMISSION_DESK
  ACCOUNTS
  TEACHER
  CLASS_TEACHER
  RECEPTION
  TRANSPORT_MANAGER
  HR_ADMIN
  PARENT
  STUDENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AdmissionStatus {
  ENQUIRY
  REGISTERED
  PENDING_REVIEW
  APPROVED
  REJECTED
  WAITLIST
  ADMITTED
  WITHDRAWN
}

enum FeeTxnType {
  INVOICE
  PAYMENT
  CONCESSION
  LATE_FEE
  REFUND
  ADJUSTMENT
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE
}

enum LeadTemperature {
  HOT
  WARM
  COLD
}

enum FollowUpChannel {
  CALL
  WHATSAPP
  VISIT
  EMAIL
  OTHER
}

model SchoolProfile {
  id            String   @id @default(cuid())
  name          String   @default("BHB International School")
  board         String   @default("CBSE")
  tagline       String?
  established   Int?
  addressLine1  String?
  addressLine2  String?
  city          String?
  state         String?
  pincode       String?
  phone         String?
  email         String?
  website       String?
  logoUrl       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String?
  name      String?
  role      UserRole @default(OFFICE_ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs            AuditLog[]
  staffProfile         Staff?
  assignedEnquiries    Enquiry[]         @relation("EnquiryAssignedTo")
  enquiryFollowUpsMade EnquiryFollowUp[]
  surveysConducted     Survey[]
}

model AcademicSession {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)

  classes      Class[]
  subjects     Subject[]
  feeHeads     FeeHead[]
  feeStructures FeeStructure[]
  students     Student[]
  enquiries    Enquiry[]
  admissions   Admission[]
  homework     HomeworkEntry[]
  classDiary   ClassDiaryEntry[]
  exams         Exam[]
  gradeBands    GradeBand[]
  documentTypes DocumentTypeMaster[]
  surveys       Survey[]
  onlineLeads   OnlineLead[]
  campaignTracking CampaignTracking[]
  expenses      Expense[]
  schoolNotices SchoolNotice[]
  complaintTickets ComplaintTicket[]
  busStops         BusStop[]
  transportRoutes  TransportRoute[]
  contentMappings  ContentMapping[]
  contentUsage     ContentUsage[]
  studentContentActivity StudentContentActivity[]
  payrollRuns      PayrollRun[]
}

/// Session-scoped notice board (parents portal / staff can consume later)
model SchoolNotice {
  id          String   @id @default(cuid())
  sessionId   String
  session     AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  title       String
  body        String   @db.Text
  pinned      Boolean  @default(false)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sessionId])
  @@index([publishedAt])
}

/// Front-office / parent grievance log — blueprint communication
model ComplaintTicket {
  id            String   @id @default(cuid())
  sessionId     String
  session       AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  raisedByName  String?
  phone         String?
  email         String?
  subject       String
  body          String   @db.Text
  status        String   @default("OPEN")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([sessionId])
  @@index([status])
  @@index([createdAt])
}

/// Grading scale for the session: assign label when percentage >= minPercent (use highest matching band).
model GradeBand {
  id         String   @id @default(cuid())
  sessionId  String
  session    AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  label      String
  minPercent Decimal  @db.Decimal(5, 2)
  sortOrder  Int      @default(0)

  @@index([sessionId])
}

model Class {
  id        String @id @default(cuid())
  sessionId String
  session   AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int    @default(0)

  sections       Section[]
  feeStructures  FeeStructure[]

  @@unique([sessionId, name])
  @@index([sessionId])
}

model Section {
  id      String @id @default(cuid())
  classId String
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  name    String

  students Student[]
  homework HomeworkEntry[]
  diary    ClassDiaryEntry[]
  proposedAdmissionDrafts Admission[] @relation("AdmissionProposedSection")

  @@unique([classId, name])
  @@index([classId])
}

model Subject {
  id        String @id @default(cuid())
  sessionId String
  session   AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name      String
  code      String?

  homework HomeworkEntry[]
  marks    Mark[]
  contentMappings ContentMapping[]
  contentUsage    ContentUsage[]
  studentActivity StudentContentActivity[]

  @@unique([sessionId, name])
  @@index([sessionId])
}

model Exam {
  id        String   @id @default(cuid())
  sessionId String
  session   AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name      String
  termLabel String?
  examDate  DateTime? @db.Date
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  marks Mark[]

  @@index([sessionId])
}

model Mark {
  id            String   @id @default(cuid())
  examId        String
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectId     String
  subject       Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  marksObtained Decimal  @db.Decimal(8, 2)
  maxMarks      Decimal  @db.Decimal(8, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([examId, studentId, subjectId])
  @@index([examId])
  @@index([studentId])
}

/// Homework or classwork assigned to a section (optionally tied to a subject).
model HomeworkEntry {
  id          String   @id @default(cuid())
  sessionId   String
  session     AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sectionId   String
  section     Section   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subjectId   String?
  subject     Subject?  @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  kind        String    @default("HOMEWORK")
  title       String
  description String?
  assignedOn  DateTime  @db.Date
  dueDate     DateTime? @db.Date
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([sessionId, sectionId])
  @@index([assignedOn])
}

/// One diary note per section per calendar day.
model ClassDiaryEntry {
  id         String   @id @default(cuid())
  sessionId  String
  session    AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sectionId  String
  section    Section   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  entryDate  DateTime  @db.Date
  summary    String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([sectionId, entryDate])
  @@index([sessionId])
}

model FeeHead {
  id        String @id @default(cuid())
  sessionId String
  session   AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int    @default(0)

  structures    FeeStructure[]
  feePayments   FeeTransaction[]

  @@unique([sessionId, name])
  @@index([sessionId])
}

/// Class-wise fee plan amounts per fee head
model FeeStructure {
  id        String @id @default(cuid())
  sessionId String
  session   AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  classId   String
  class     Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  headId    String
  head      FeeHead @relation(fields: [headId], references: [id], onDelete: Cascade)
  amount    Decimal @db.Decimal(12, 2)

  @@unique([sessionId, classId, headId])
  @@index([sessionId])
  @@index([classId])
}

model Parent {
  id           String   @id @default(cuid())
  fatherName   String?
  motherName   String?
  guardianName String?
  phonePrimary String
  phoneAlt     String?
  email        String?
  address      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  students StudentParent[]
}

model Student {
  id            String   @id @default(cuid())
  sessionId     String
  session       AcademicSession @relation(fields: [sessionId], references: [id])
  sectionId     String?
  section       Section? @relation(fields: [sectionId], references: [id])
  admissionNo   String?  @unique
  firstName     String
  lastName      String?
  dob           DateTime?
  gender        Gender?
  category      String?
  religion      String?
  bloodGroup    String?
  aadhaarLast4  String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  parents     StudentParent[]
  admission   Admission?
  feeTxns     FeeTransaction[]
  attendances StudentAttendance[]
  marks       Mark[]
  transportAssignment StudentTransportAssignment?
  contentActivity StudentContentActivity[]

  @@index([sessionId])
  @@index([sectionId])
}

/// One row per student per calendar day (session scoped via student.sessionId).
model StudentAttendance {
  id         String            @id @default(cuid())
  studentId  String
  student    Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date       DateTime          @db.Date
  status     AttendanceStatus
  remarks    String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@unique([studentId, date])
  @@index([date])
  @@index([studentId])
}

model StudentParent {
  studentId String
  parentId  String
  relation  String   @default("Father")
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent    Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@id([studentId, parentId])
}

model Enquiry {
  id           String   @id @default(cuid())
  sessionId    String
  session      AcademicSession @relation(fields: [sessionId], references: [id])
  childName    String
  parentName   String?
  phone        String
  email        String?
  source       String?
  classSeeking String?
  status       String   @default("NEW")
  notes        String?
  nextFollowUp DateTime?
  assignedToId String?
  assignedTo   User?    @relation("EnquiryAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  leadTemperature LeadTemperature?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  admission   Admission?
  followUps   EnquiryFollowUp[]
  surveyEntry SurveyEntry?
  onlineLead  OnlineLead?

  @@index([sessionId])
  @@index([phone])
  @@index([assignedToId])
}

/// Structured follow-up log (call / WhatsApp / visit) — blueprint §1.2
model EnquiryFollowUp {
  id           String          @id @default(cuid())
  enquiryId    String
  enquiry      Enquiry         @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  channel      FollowUpChannel @default(CALL)
  summary      String
  nextFollowUp DateTime?
  createdById  String?
  createdBy    User?           @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime        @default(now())

  @@index([enquiryId])
  @@index([createdAt])
}

model Admission {
  id          String          @id @default(cuid())
  sessionId   String
  session     AcademicSession @relation(fields: [sessionId], references: [id])
  enquiryId   String?         @unique
  enquiry     Enquiry?        @relation(fields: [enquiryId], references: [id])
  studentId   String?         @unique
  student     Student?        @relation(fields: [studentId], references: [id])
  status      AdmissionStatus @default(ENQUIRY)
  remarks     String?

  proposedSectionId   String?
  proposedSection     Section? @relation("AdmissionProposedSection", fields: [proposedSectionId], references: [id], onDelete: SetNull)
  proposedAdmissionNo String?
  draftFirstName      String?
  draftLastName       String?
  draftDob            DateTime? @db.Date
  draftGender         Gender?

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  documents   AdmissionDocument[]
  feePayments AdmissionFeePayment[]

  @@index([sessionId])
  @@index([status])
}

/// Master checklist labels per session (e.g. Birth certificate, Aadhaar)
model DocumentTypeMaster {
  id                   String   @id @default(cuid())
  sessionId            String
  session              AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name                 String
  requiredForAdmission Boolean  @default(true)
  sortOrder            Int      @default(0)

  admissionDocs AdmissionDocument[]

  @@unique([sessionId, name])
  @@index([sessionId])
}

/// Per-admission document status — blueprint §1.4
model AdmissionDocument {
  id             String   @id @default(cuid())
  admissionId    String
  admission      Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  documentTypeId String?
  documentType   DocumentTypeMaster? @relation(fields: [documentTypeId], references: [id], onDelete: SetNull)
  label          String
  status         String   @default("PENDING")
  fileUrl        String?
  verifiedAt     DateTime?
  remarks        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([admissionId])
}

/// Admission fee before student record — blueprint §1.5
model AdmissionFeePayment {
  id          String    @id @default(cuid())
  admissionId String
  admission   Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  amount      Decimal   @db.Decimal(12, 2)
  isFull      Boolean   @default(true)
  receiptNo   String?
  description String?
  paidAt      DateTime  @default(now())

  @@index([admissionId])
}

/// Field survey run — blueprint §2
model Survey {
  id          String   @id @default(cuid())
  sessionId   String
  session     AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  staffUserId String?
  staffUser   User?    @relation(fields: [staffUserId], references: [id], onDelete: SetNull)
  areaTag     String?
  notes       String?
  createdAt   DateTime @default(now())

  entries SurveyEntry[]

  @@index([sessionId])
}

model SurveyEntry {
  id            String   @id @default(cuid())
  surveyId      String
  survey        Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  childName     String
  phone         String
  parentName    String?
  classSeeking  String?
  interestLevel String?
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)
  enquiryId     String?  @unique
  enquiry       Enquiry? @relation(fields: [enquiryId], references: [id], onDelete: SetNull)
  notes         String?
  createdAt     DateTime @default(now())

  @@index([surveyId])
  @@index([phone])
}

/// Webhook / form leads — blueprint §3
model OnlineLead {
  id           String   @id @default(cuid())
  sessionId    String
  session      AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  campaignTrackingId String?
  campaignTracking   CampaignTracking? @relation(fields: [campaignTrackingId], references: [id], onDelete: SetNull)
  source       String
  campaign     String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  utmContent   String?
  rawPayload   Json?
  childName    String?
  phone        String?
  email        String?
  enquiryId    String?  @unique
  enquiry      Enquiry? @relation(fields: [enquiryId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([sessionId])
  @@index([createdAt])
  @@index([campaignTrackingId])
}

/// Marketing attribution and ROI layer for Meta / Google / website campaigns.
model CampaignTracking {
  id            String   @id @default(cuid())
  sessionId      String
  session        AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  source         String
  campaignName   String
  medium         String?
  formName       String?
  landingUrl     String?
  budgetAmount   Decimal? @db.Decimal(12, 2)
  spendAmount    Decimal? @db.Decimal(12, 2)
  startsOn       DateTime? @db.Date
  endsOn         DateTime? @db.Date
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  onlineLeads OnlineLead[]

  @@index([sessionId])
  @@index([source])
  @@index([campaignName])
}

/// Org staff (HR, transport, teachers) — attendance & advances
model Staff {
  id           String   @id @default(cuid())
  userId       String?  @unique
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  employeeCode String?  @unique
  firstName    String
  lastName     String?
  phone        String?
  email        String?
  designation  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  advances StaffAdvance[]

  @@index([isActive])
}

/// Daily expenses — blueprint §12
model Expense {
  id          String   @id @default(cuid())
  sessionId   String
  session     AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  category    String
  amount      Decimal  @db.Decimal(12, 2)
  description String?
  vendor      String?
  paidAt      DateTime @default(now())
  receiptUrl  String?

  @@index([sessionId])
  @@index([paidAt])
}

model StaffAdvance {
  id        String   @id @default(cuid())
  staffId   String
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(12, 2)
  purpose   String?
  givenAt   DateTime @default(now())
  balance   Decimal  @db.Decimal(12, 2)

  recoveries AdvanceRecovery[]

  @@index([staffId])
}

model AdvanceRecovery {
  id          String       @id @default(cuid())
  advanceId   String
  advance     StaffAdvance @relation(fields: [advanceId], references: [id], onDelete: Cascade)
  amount      Decimal      @db.Decimal(12, 2)
  recoveredAt DateTime     @default(now())
  payrollRef  String?

  @@index([advanceId])
}

/// Transport — blueprint §13–14
model Vehicle {
  id             String   @id @default(cuid())
  registrationNo String   @unique
  model          String?
  fuelType       String?
  driverName     String?
  driverPhone    String?
  isBlocked      Boolean  @default(false)
  blockReason    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  documents         VehicleDocument[]
  driverDocuments   DriverDocument[]
  fuelIssues        FuelIssue[]
  fuelStockEntries  FuelStockEntry[]
  defaultForRoutes  TransportRoute[]

  @@index([isBlocked])
}

/// Session-scoped pickup/drop points (master list)
model BusStop {
  id        String   @id @default(cuid())
  sessionId String
  session   AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name      String
  area      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  routeStops RouteStop[]
  boardingFor StudentTransportAssignment[]

  @@unique([sessionId, name])
  @@index([sessionId])
}

model TransportRoute {
  id               String   @id @default(cuid())
  sessionId        String
  session          AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name             String
  code             String?
  defaultVehicleId String?
  defaultVehicle   Vehicle? @relation(fields: [defaultVehicleId], references: [id], onDelete: SetNull)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  stops                RouteStop[]
  studentAssignments   StudentTransportAssignment[]

  @@unique([sessionId, name])
  @@index([sessionId])
  @@index([defaultVehicleId])
}

/// Ordered stops on a route (pickup sequence)
model RouteStop {
  id          String         @id @default(cuid())
  routeId     String
  route       TransportRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  busStopId   String
  busStop     BusStop        @relation(fields: [busStopId], references: [id], onDelete: Restrict)
  sortOrder   Int
  pickupTime  String?
  dropTime    String?

  @@unique([routeId, busStopId])
  @@unique([routeId, sortOrder])
  @@index([routeId])
  @@index([busStopId])
}

model StudentTransportAssignment {
  id             String   @id @default(cuid())
  studentId      String   @unique
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  routeId        String
  route          TransportRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  boardingStopId String
  boardingStop   BusStop  @relation(fields: [boardingStopId], references: [id], onDelete: Restrict)
  remarks        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([routeId])
  @@index([boardingStopId])
}

model VehicleDocument {
  id         String    @id @default(cuid())
  vehicleId  String
  vehicle    Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  docType    String
  expiresOn  DateTime? @db.Date
  fileUrl    String?
  issuedOn   DateTime? @db.Date
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([vehicleId])
  @@index([expiresOn])
}

model DriverDocument {
  id          String    @id @default(cuid())
  vehicleId    String
  vehicle      Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverName   String
  docType      String
  identifier   String?
  expiresOn    DateTime? @db.Date
  fileUrl      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([vehicleId])
  @@index([expiresOn])
}

model FuelPurchase {
  id             String   @id @default(cuid())
  quantityLiters Decimal  @db.Decimal(10, 2)
  ratePerLiter   Decimal? @db.Decimal(10, 2)
  totalAmount    Decimal  @db.Decimal(12, 2)
  vendor         String?
  purchasedAt    DateTime @default(now())
  notes          String?

  @@index([purchasedAt])
}

/// Central stock ledger for transport fuel store.
model FuelStockEntry {
  id             String   @id @default(cuid())
  vehicleId       String?
  vehicle         Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  quantityLiters  Decimal  @db.Decimal(10, 2)
  direction       String
  referenceType   String?
  referenceId     String?
  recordedAt      DateTime @default(now())
  notes           String?

  @@index([vehicleId])
  @@index([recordedAt])
}

model FuelIssue {
  id             String   @id @default(cuid())
  vehicleId      String
  vehicle        Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  quantityLiters Decimal  @db.Decimal(10, 2)
  odometerKm     Decimal? @db.Decimal(12, 2)
  issuedAt       DateTime @default(now())
  notes          String?

  @@index([vehicleId])
}

/// Inventory — blueprint §15
model InventoryItem {
  id           String   @id @default(cuid())
  sku          String?
  name         String
  unit         String   @default("PCS")
  qtyOnHand    Decimal  @default(0) @db.Decimal(12, 2)
  reorderLevel Decimal? @db.Decimal(12, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transactions InventoryTxn[]

  @@index([name])
}

model InventoryTxn {
  id        String        @id @default(cuid())
  itemId    String
  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  qty       Decimal       @db.Decimal(12, 2)
  direction String
  ref       String?
  createdAt DateTime      @default(now())

  @@index([itemId])
  @@index([createdAt])
}

/// Smart content catalog — blueprint §6 (Pearson / Leads / internal)
model ContentAsset {
  id          String   @id @default(cuid())
  title       String
  provider    String?
  subjectHint String?
  gradeHint   String?
  externalUrl String?
  meta        Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mappings        ContentMapping[]
  usageRecords    ContentUsage[]
  studentActivity StudentContentActivity[]

  @@index([provider])
}

/// Chapter / curriculum mapping for smart content providers such as Pearson or Leads.
model ContentMapping {
  id             String   @id @default(cuid())
  sessionId       String
  session         AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  contentAssetId  String
  contentAsset    ContentAsset @relation(fields: [contentAssetId], references: [id], onDelete: Cascade)
  subjectId       String?
  subject         Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  className       String?
  chapterName     String?
  topicName       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([sessionId])
  @@index([contentAssetId])
  @@index([subjectId])
}

/// Staff-side usage log for smart content recommendations and playback.
model ContentUsage {
  id             String   @id @default(cuid())
  sessionId       String
  session         AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  contentAssetId  String
  contentAsset    ContentAsset @relation(fields: [contentAssetId], references: [id], onDelete: Cascade)
  subjectId       String?
  subject         Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  usedByName      String?
  usedForClass    String?
  usedForSection  String?
  usageType       String   @default("CLASSROOM")
  durationMinutes Int?
  usedAt          DateTime @default(now())

  @@index([sessionId])
  @@index([contentAssetId])
  @@index([subjectId])
  @@index([usedAt])
}

/// Student-level interaction telemetry for content engagement and weak-area analysis.
model StudentContentActivity {
  id             String   @id @default(cuid())
  sessionId       String
  session         AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentId       String
  student         Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  contentAssetId  String
  contentAsset    ContentAsset @relation(fields: [contentAssetId], references: [id], onDelete: Cascade)
  subjectId       String?
  subject         Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  activityType    String
  progressPercent Decimal? @db.Decimal(5, 2)
  scorePercent    Decimal? @db.Decimal(5, 2)
  occurredAt      DateTime @default(now())

  @@index([sessionId])
  @@index([studentId])
  @@index([contentAssetId])
  @@index([subjectId])
  @@index([occurredAt])
}

model FeeTransaction {
  id          String     @id @default(cuid())
  studentId   String
  student     Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type        FeeTxnType
  amount      Decimal    @db.Decimal(12, 2)
  description String?
  receiptNo   String?
  paidAt      DateTime   @default(now())
  createdAt   DateTime   @default(now())

  /// Optional: which fee head this payment is allocated to (for head-wise reports).
  feeHeadId   String?
  feeHead     FeeHead?   @relation(fields: [feeHeadId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([paidAt])
  @@index([feeHeadId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([entity, entityId])
}

/// Monthly payroll and finance automation anchor.
model PayrollRun {
  id             String   @id @default(cuid())
  sessionId       String
  session         AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  monthLabel      String
  status          String   @default("DRAFT")
  grossAmount     Decimal? @db.Decimal(12, 2)
  deductionsAmount Decimal? @db.Decimal(12, 2)
  netAmount       Decimal? @db.Decimal(12, 2)
  processedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([sessionId])
  @@index([monthLabel])
  @@index([status])
}
